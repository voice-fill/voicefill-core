{
  "name": "@voicefill/core",
  "version": "0.1.0",
  "description": "Voice-driven form filling — transcribe audio and extract structured data with OpenAI",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "zod": "^3.23.0"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.63",
    "ai": "^6.0.180",
    "openai": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "zod": "^3.24.0"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
